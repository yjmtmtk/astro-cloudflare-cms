{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "paths": { "@/*": ["./src/*"] },
    "types": ["@types/node", "@cloudflare/workers-types", "@cloudflare/vitest-pool-workers", "astro/client"]
  },
  "include": ["src", "test"]
}
