{
  "name": "astro-cloudflare-cms",
  "version": "0.1.0",
  "description": "Drop-in D1+R2 CMS for Astro + Cloudflare + React sites — an Astro integration that injects admin UI, public /news, auth, and media.",
  "keywords": ["astro", "astro-integration", "cloudflare", "d1", "r2", "cms", "react"],
  "license": "MIT",
  "author": "yjmtmtk",
  "repository": {
    "type": "git",
    "url": "https://github.com/yjmtmtk/astro-cloudflare-cms"
  },
  "homepage": "https://github.com/yjmtmtk/astro-cloudflare-cms",
  "type": "module",
  "exports": {
    ".": "./src/integration.ts",
    "./types": "./src/lib/types.ts",
    "./data": "./src/data.ts",
    "./news": "./src/news/index.ts",
    "./styles.css": "./styles.css"
  },
  "bin": {
    "astro-cloudflare-cms": "./bin/cli.mjs"
  },
  "files": ["src", "migrations", "styles.css", "bin"],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "build:css": "tailwindcss -c ./tailwind.config.mjs -i ./src/styles/input.css -o ./styles.css --minify"
  },
  "peerDependencies": {
    "astro": "^7",
    "react": "^19",
    "react-dom": "^19"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-label": "^2.1.10",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-separator": "^1.1.10",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tooltip": "^1.2.10",
    "@tiptap/extension-image": "^3.27.1",
    "@tiptap/pm": "^3.27.1",
    "@tiptap/react": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.21.0",
    "nanoid": "^5.1.15",
    "tailwind-merge": "^3.6.0",
    "ultrahtml": "^1.6.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.6.0",
    "@cloudflare/workers-types": "^4.20240000.0",
    "@tailwindcss/typography": "^0.5.15",
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "astro": "^7.0.0",
    "patch-package": "^8.0.1",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.6.0",
    "vitest": "~2.1.0"
  }
}
