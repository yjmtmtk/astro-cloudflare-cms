---
export const prerender = false;
import '../../../styles.css';
import { env } from 'cloudflare:workers';
import { getPublicArticleBySlug, getArticleBySlug } from '../../lib/db-articles';
import { canManageArticle } from '../../lib/authz';
import { eyecatchOf } from '../../lib/eyecatch';
import { renderBody } from '../../lib/render-body';
import { config } from 'virtual:acc-config';
const slug = Astro.params.slug!;
const now = Math.floor(Date.now() / 1000);

let article = await getPublicArticleBySlug(env.DB, slug, now);
let preview = false;
if (!article) {
  const candidate = await getArticleBySlug(env.DB, slug);
  if (candidate && canManageArticle(Astro.locals.user, candidate)) {
    article = candidate;
    preview = true;
  }
}
if (!article) return new Response('Not found', { status: 404 });

const hero = eyecatchOf(
  { title: article.title, eyecatch_url: article.eyecatch_url, category_id: article.category_id },
  { baseUrl: env.PUBLIC_R2_BASE_URL, defaultUrl: env.DEFAULT_EYECATCH_URL }
);
const html = renderBody(article.body, env.PUBLIC_R2_BASE_URL);
const fmt = (e: number) => new Date(e * 1000).toLocaleDateString('ja-JP');
---
<html lang="ja">
  <head><meta charset="utf-8" /><title>{article.title}</title></head>
  <body class="min-h-screen bg-background">
    {preview && (
      <div class="bg-yellow-400 px-4 py-2 text-center text-sm font-semibold text-yellow-950">
        プレビュー中（未公開）— この表示はログイン中のあなたにのみ見えています
      </div>
    )}
    <main class="mx-auto max-w-3xl p-4">
      <a
        href={config.newsBasePath}
        class="mb-4 inline-flex items-center gap-1 text-sm text-muted-foreground hover:text-foreground"
      >
        <span aria-hidden="true">←</span> News一覧へ
      </a>
      <img src={hero} alt="" class="mb-4 aspect-video w-full rounded-lg object-cover" />
      <time class="text-sm text-muted-foreground">{fmt(article.publish_at)}</time>
      <h1 class="mb-4 mt-1 text-2xl font-bold">{article.title}</h1>
      <article class="prose max-w-none" set:html={html} />
    </main>
  </body>
</html>
