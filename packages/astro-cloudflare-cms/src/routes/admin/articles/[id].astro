---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { env } from 'cloudflare:workers';
import { isMaster } from '../../../lib/authz';
import ArticleForm from '../../../components/ArticleForm.tsx';
import { getArticleById } from '../../../lib/db-articles';
import { canManageArticle } from '../../../lib/authz';
import { config } from 'virtual:acc-config';
const user = Astro.locals.user!;
const id = Astro.params.id!;
const article = await getArticleById(env.DB, id);
if (!article) return new Response('Not found', { status: 404 });
if (!canManageArticle(user, article)) return Astro.redirect(config.adminBasePath);
---
<AdminLayout
  title="記事編集"
  currentPath={Astro.url.pathname}
  isMaster={isMaster(user)}
  userName={user.name}
  userRole={user.role}
>
  <ArticleForm client:load mode="edit" initial={article} />
</AdminLayout>
