---
import '../../../styles.css';
import { listPublicArticles } from '../../lib/db-articles';
import { eyecatchOf } from '../../lib/eyecatch';
import { config } from 'virtual:acc-config';
const env = Astro.locals.runtime.env;
const now = Math.floor(Date.now() / 1000);
const articles = await listPublicArticles(env.DB, now);
const fmt = (e: number) => new Date(e * 1000).toLocaleDateString('ja-JP');
---
<html lang="ja">
  <head><meta charset="utf-8" /><title>News</title></head>
  <body class="min-h-screen bg-background">
    <main class="mx-auto max-w-4xl p-4">
      <h1 class="mb-4 text-2xl font-bold">News</h1>
      {/* Reference template — adjust layout/styles to the host site. */}
      <ul class="grid gap-4 sm:grid-cols-2">
        {articles.map((a) => (
          <li class="overflow-hidden rounded-lg border">
            <a href={`${config.newsBasePath}/${a.slug}`}>
              <img src={eyecatchOf({ title: a.title, eyecatch_url: a.eyecatch_url, category_id: a.category_id }, { baseUrl: env.PUBLIC_R2_BASE_URL, defaultUrl: env.DEFAULT_EYECATCH_URL })} alt="" class="aspect-video w-full object-cover" />
              <div class="p-4">
                <time class="text-xs text-muted-foreground">{fmt(a.publish_at)}</time>
                <h2 class="font-semibold">{a.title}</h2>
                {a.excerpt && <p class="mt-1 text-sm text-muted-foreground">{a.excerpt}</p>}
              </div>
            </a>
          </li>
        ))}
      </ul>
      {articles.length === 0 && <p class="text-muted-foreground">記事はまだありません。</p>}
    </main>
  </body>
</html>
